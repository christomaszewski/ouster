#!/usr/bin/env bash
# ouster-up <sensor-config.yaml> [up [-d] | down | status | logs [args] | config | ...]
#
# Bring up ONE Ouster lidar from ONE generic rig config (the single source of truth). Reads the
# config, derives the instance identity (ROS namespace /<name>; compose project = an inherited
# COMPOSE_PROJECT_NAME — rig owns it — or ouster_<name> standalone), renders the UPSTREAM driver's
# ROS 2 params file, and runs `docker compose`. It SELECTS + PARAMETERIZES a static compose file —
# it never generates one.
#
#   ouster-up sensors/ouster_top.yaml            # up (foreground)
#   ouster-up sensors/ouster_top.yaml up -d      # detached
#   ouster-up sensors/ouster_top.yaml status     # docker compose ps
#   ouster-up sensors/ouster_top.yaml logs -f
#   ouster-up sensors/ouster_top.yaml down
#   ouster-up sensors/ouster_top.yaml config     # render the merged compose
#   ouster-up /any/host/path/ouster_top.yaml up -d   # config from anywhere (rig)
#
# Multiple sensors = run it per config; each is its own compose project + ROS namespace, so
# instances never collide. This repo does NOT depend on rig (one-way; see rigging.yaml).
set -euo pipefail
REPO="$(cd "$(dirname "$0")" && pwd)"
PYTHON="${OUSTER_PYTHON:-python3}"

CONFIG="${1:?usage: ouster-up <sensor-config.yaml> [up [-d]|down|status|logs|config|...]}"
shift || true
[ -f "$CONFIG" ] || { echo "ouster-up: config not found: $CONFIG" >&2; exit 1; }
CONFIG_ABS="$(cd "$(dirname "$CONFIG")" && pwd)/$(basename "$CONFIG")"

if ! docker compose version >/dev/null 2>&1; then
  echo "ouster-up: needs the Docker Compose v2 plugin ('docker compose')" >&2
  exit 1
fi

# config -> instance identity (SERVICE / NAME / NAMESPACE / TYPE). Tokens, no spaces.
eval "$("$PYTHON" "$REPO/tools/render_params.py" --env "$CONFIG_ABS" | sed 's/^/export /')"
PROJECT="${SERVICE}_${NAME}"

# Render the ROS 2 params file to a host staging path (one rendered file per instance).
mkdir -p "$REPO/var/run"
PARAMS_HOST="$REPO/var/run/${NAME}.params.yaml"
"$PYTHON" "$REPO/tools/render_params.py" "$CONFIG_ABS" > "$PARAMS_HOST"

# Compose env: this instance's params file, ROS namespace, and instance name (the metadata volume
# is ouster_<name>_metadata). The deploy image is resolved by the compose file itself (OUSTER_IMAGE
# override -> RIG_IMAGE_REGISTRY -> local ouster_driver:latest), so a standalone run needs no rig
# and no registry; export OUSTER_IMAGE to force a specific image.
export OUSTER_PARAMS_HOST="$PARAMS_HOST"
export OUSTER_NAMESPACE="$NAMESPACE"
export OUSTER_NAME="$NAME"

FILES=(-f "$REPO/docker/compose/compose.deploy.yaml")

# Verbs: `status` -> `ps`; everything else is forwarded to `docker compose` verbatim. No args = up.
ARGS=("$@")
[ ${#ARGS[@]} -eq 0 ] && ARGS=(up)
[ "${ARGS[0]}" = "status" ] && ARGS=(ps "${ARGS[@]:1}")

# The driver persists sensor metadata to ~/.ros/{hostname}_metadata.json; compose mounts the
# per-instance external volume ouster_<name>_metadata there (rig GCs it only on `rig down --purge`).
# Ensure it exists before a bring-up — `config`/`down`/`status`/`logs` stay side-effect-free so
# `rig certify` can render `config` under a poisoned env.
[ "${ARGS[0]}" = "up" ] && docker volume create "ouster_${NAME}_metadata" >/dev/null

# rig owns the compose project name (it exports COMPOSE_PROJECT_NAME per call); honor it when
# inherited, fall back to <service>_<name> standalone. NEVER pass -p — overriding the orchestrator's
# project name orphans the containers from `rig status`/`rig down`.
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-$PROJECT}"

echo "ouster-up: project=$COMPOSE_PROJECT_NAME namespace=$NAMESPACE params=$PARAMS_HOST" >&2
exec docker compose "${FILES[@]}" "${ARGS[@]}"
